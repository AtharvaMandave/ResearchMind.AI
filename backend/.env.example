# ──────────────────────────────────────────────────────────────────────────────
#  ResearchMind AI – Environment Configuration
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="ResearchMind AI"
APP_VERSION="0.1.0"
DEBUG=true
ENVIRONMENT=development          # development | staging | production

# ── API Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=true                      # auto-reload on code changes (dev only)

# ── PostgreSQL (pgvector) ─────────────────────────────────────────────────────
POSTGRES_USER=researchmind
POSTGRES_PASSWORD=researchmind_secret
POSTGRES_DB=researchmind_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://researchmind:researchmind_secret@localhost:5432/researchmind_db

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Swap to GOOGLE_API_KEY if using Gemini
OPENAI_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-4o-mini            # gpt-4o | gpt-4o-mini | gemini-1.5-pro
EMBEDDING_MODEL=text-embedding-3-small

# ── Search APIs ───────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-your-tavily-key-here

# ── Vector Store ─────────────────────────────────────────────────────────────
EMBEDDING_DIMENSIONS=1536        # 1536 for text-embedding-3-small

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
MAX_SEARCH_RESULTS_PER_QUERY=10
MAX_AGENT_ITERATIONS=3           # max feedback loops in LangGraph
